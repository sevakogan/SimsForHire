---
export const prerender = false

import { requireAuth } from '../../lib/admin-auth'

const auth = await requireAuth(Astro.request)
if (auth.authorized) {
  return Astro.redirect('/admin/dashboard')
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <title>Sign In — SimsForHire</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        background: #F5F5F7;
        color: #1D1D1F;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        -webkit-font-smoothing: antialiased;
      }
      .login-card {
        width: 100%;
        max-width: 400px;
        padding: 0 24px;
      }
      .logo-mark {
        width: 48px;
        height: 48px;
        background: #1D1D1F;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
      }
      .logo-mark span {
        color: white;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
      }
      h1 {
        font-size: 28px;
        font-weight: 600;
        text-align: center;
        letter-spacing: -0.5px;
        margin-bottom: 4px;
      }
      .subtitle {
        text-align: center;
        color: #86868B;
        font-size: 15px;
        margin-bottom: 40px;
      }
      .field {
        margin-bottom: 16px;
      }
      label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #1D1D1F;
        margin-bottom: 6px;
      }
      input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #E5E5E7;
        border-radius: 10px;
        font-size: 15px;
        font-family: inherit;
        color: #1D1D1F;
        background: white;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      input:focus {
        border-color: #1D1D1F;
        box-shadow: 0 0 0 3px rgba(29, 29, 31, 0.08);
        outline: none;
      }
      input::placeholder {
        color: #AEAEB2;
      }
      button[type="submit"] {
        width: 100%;
        padding: 13px;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        font-family: inherit;
        color: white;
        background: #1D1D1F;
        cursor: pointer;
        margin-top: 8px;
        transition: opacity 0.2s;
      }
      button[type="submit"]:hover {
        opacity: 0.85;
      }
      button[type="submit"]:active {
        transform: scale(0.99);
      }
      button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }
      .error-msg {
        text-align: center;
        color: #E10600;
        font-size: 14px;
        margin-top: 16px;
        display: none;
      }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 32px;
        color: #86868B;
        font-size: 13px;
        text-decoration: none;
        transition: color 0.2s;
      }
      .back-link:hover {
        color: #1D1D1F;
      }
    </style>
  </head>
  <body>
    <div class="login-card">
      <div class="logo-mark"><span>S4H</span></div>
      <h1>Welcome back</h1>
      <p class="subtitle">Sign in to SimsForHire Admin</p>

      <form id="login-form">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@simsforhire.com" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="Enter password" />
        </div>
        <button type="submit">Sign In</button>
        <div id="login-error" class="error-msg"></div>
      </form>

      <button id="forgot-btn" style="display:block;width:100%;margin-top:16px;padding:12px;border:1px solid #E5E5E7;border-radius:10px;font-size:14px;font-weight:500;font-family:inherit;color:#86868B;background:transparent;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='#1D1D1F';this.style.color='#1D1D1F'" onmouseout="this.style.borderColor='#E5E5E7';this.style.color='#86868B'">Forgot Password?</button>
      <div id="reset-form" style="display:none;margin-top:16px;padding:16px;background:#F0F7FF;border:1px solid #D4E5F7;border-radius:10px;">
        <p style="font-size:13px;color:#1D1D1F;margin-bottom:12px;font-weight:500;">Reset your password</p>
        <input type="email" id="reset-email" placeholder="Your email address" style="width:100%;padding:10px 14px;border:1px solid #D4E5F7;border-radius:8px;font-size:14px;font-family:inherit;outline:none;margin-bottom:10px;box-sizing:border-box;" />
        <div style="display:flex;gap:8px;">
          <button id="send-reset" style="flex:2;padding:10px;border:none;border-radius:8px;font-size:13px;font-weight:500;font-family:inherit;background:#2563EB;color:white;cursor:pointer;">Send Reset Link</button>
          <button id="cancel-reset" style="flex:1;padding:10px;border:1px solid #D4E5F7;border-radius:8px;font-size:13px;font-weight:500;font-family:inherit;background:white;color:#86868B;cursor:pointer;">Cancel</button>
        </div>
        <p id="reset-status" style="font-size:12px;margin-top:8px;display:none;"></p>
      </div>

      <a href="/" class="back-link">← Back to simsforhire.com</a>
    </div>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement
      const errorEl = document.getElementById('login-error')!

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        errorEl.style.display = 'none'
        const btn = form.querySelector('button') as HTMLButtonElement
        btn.disabled = true
        btn.textContent = 'Signing in…'

        const fd = new FormData(form)
        try {
          const res = await fetch('/api/admin/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: fd.get('email'), password: fd.get('password') }),
          })
          if (res.ok) {
            window.location.href = '/admin/dashboard'
          } else {
            const data = await res.json()
            errorEl.textContent = data.error || 'Invalid credentials'
            errorEl.style.display = 'block'
          }
        } catch {
          errorEl.textContent = 'Connection error. Try again.'
          errorEl.style.display = 'block'
        } finally {
          btn.disabled = false
          btn.textContent = 'Sign In'
        }
      })

      // Forgot password
      const forgotBtn = document.getElementById('forgot-btn')!
      const resetForm = document.getElementById('reset-form')!
      const cancelReset = document.getElementById('cancel-reset')!
      const sendReset = document.getElementById('send-reset')!
      const resetStatus = document.getElementById('reset-status')!

      forgotBtn.addEventListener('click', () => {
        forgotBtn.style.display = 'none'
        resetForm.style.display = 'block'
        const loginEmail = (document.getElementById('email') as HTMLInputElement).value
        if (loginEmail) (document.getElementById('reset-email') as HTMLInputElement).value = loginEmail
      })

      cancelReset.addEventListener('click', () => {
        resetForm.style.display = 'none'
        forgotBtn.style.display = 'block'
        resetStatus.style.display = 'none'
      })

      sendReset.addEventListener('click', async () => {
        const email = (document.getElementById('reset-email') as HTMLInputElement).value
        if (!email.includes('@')) { resetStatus.textContent = 'Enter a valid email'; resetStatus.style.color = '#FF3B30'; resetStatus.style.display = 'block'; return }

        sendReset.textContent = 'Sending...'
        try {
          const res = await fetch('https://fzbadqjwyapipvwekgmu.supabase.co/auth/v1/recover', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ6YmFkcWp3eWFwaXB2d2VrZ211Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwMTc4NzksImV4cCI6MjA4NjU5Mzg3OX0.LjpcZaVTjDXdsZPlsZy2GON1MM_LxkMytKBMNCNQ4Zg' },
            body: JSON.stringify({ email }),
          })
          resetStatus.style.display = 'block'
          if (res.ok) {
            resetStatus.textContent = 'Reset link sent! Check your email.'
            resetStatus.style.color = '#30D158'
          } else {
            resetStatus.textContent = 'Could not send reset email'
            resetStatus.style.color = '#FF3B30'
          }
        } catch {
          resetStatus.textContent = 'Error sending reset email'
          resetStatus.style.color = '#FF3B30'
          resetStatus.style.display = 'block'
        } finally {
          sendReset.textContent = 'Send Reset Link'
        }
      })
    </script>
  </body>
</html>
