---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import Leaderboard from '../../components/Leaderboard.astro'
import { RACE_EVENTS } from '../../data/races'
import type { RaceEvent } from '../../data/races'

export function getStaticPaths() {
  return RACE_EVENTS.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }))
}

interface Props {
  event: RaceEvent
}

const { event } = Astro.props
const hasSessions = event.sessions.length > 0
---

<BaseLayout title={`${event.name} Results — SimsForHire`} ogTitle={event.name} ogSubtitle={`Race results and leaderboard times — ${event.venue}`}>
  <Navbar isSubpage />

  <div class="bg-bg">
    <!-- Event header -->
    <section class="pt-32 pb-12 px-6 md:px-16 lg:px-24">
      <div class="max-w-[980px] mx-auto">
        <!-- Back link -->
        <a
          href="/races"
          class="inline-flex items-center gap-2 text-sm text-red hover:underline mb-8"
          data-reveal
        >
          ← Back to Results
        </a>

        <!-- Type badge + date -->
        <div class="flex items-center gap-3 mb-4" data-reveal>
          <span class="text-xs text-red bg-red/10  px-3 py-1">
            {event.type}
          </span>
          <span class="text-gray text-xs">
            {event.date}
          </span>
        </div>

        <!-- Event name -->
        <h1
          class="font-display text-[clamp(3rem,7vw,5rem)] font-bold text-white leading-[1.05] tracking-tight mb-3"
          data-reveal
        >
          {event.name}
        </h1>

        <!-- Venue -->
        <p class="text-sm text-red mb-6" data-reveal>
          {event.venue}
        </p>

        <!-- Description -->
        <p class="text-gray text-base font-light max-w-2xl mb-8" data-reveal>
          {event.description}
        </p>

        <!-- Stats row -->
        {event.stats && (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-2xl" data-reveal>
            <div class="border-l-2 border-red pl-4">
              <p class="font-display text-2xl font-semibold text-white">{event.stats.totalDrivers}</p>
              <p class="text-gray text-xs">Total Drivers</p>
            </div>
            <div class="border-l-2 border-red pl-4">
              <p class="font-display text-2xl font-semibold text-white">{event.stats.totalLaps}</p>
              <p class="text-gray text-xs">Total Laps</p>
            </div>
            <div class="border-l-2 border-red pl-4">
              <p class="font-display text-2xl font-semibold text-white">{event.stats.fastestLap}</p>
              <p class="text-gray text-xs">Fastest Lap</p>
            </div>
            <div class="border-l-2 border-red pl-4">
              <p class="font-display text-2xl font-semibold text-white">{event.stats.fastestDriver}</p>
              <p class="text-gray text-xs">Fastest Driver</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Sessions + Leaderboards -->
    <section class="pb-24 px-6 md:px-16 lg:px-24">
      <div class="max-w-[980px] mx-auto">
        {hasSessions ? (
          event.sessions.map((session) => (
            <div data-reveal>
              <Leaderboard session={session} />
            </div>
          ))
        ) : (
          <div
            class="border border-white/10  py-20 flex flex-col items-center justify-center gap-4"
            data-reveal
          >
            <span class="font-display text-2xl md:text-3xl font-semibold text-gray">
              Results Coming Soon
            </span>
            <span class="text-gray text-sm font-light text-center max-w-md">
              Sessions and leaderboard times will be posted after the event
            </span>
            <a
              href="/races"
              class="mt-4 text-sm text-red hover:underline"
            >
              ← Browse other events
            </a>
          </div>
        )}
      </div>
    </section>
  </div>

  <Footer isSubpage />
</BaseLayout>
