---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
---

<BaseLayout title="Live Leaderboard — SIMSFORHIRE" ogTitle="LIVE LEADERBOARD" ogSubtitle="Real-time race results updated live">
  <Navbar isSubpage />

  <!-- Header -->
  <section class="pt-32 pb-12 px-6 md:px-16 lg:px-24 relative overflow-hidden">
    <!-- Ambient orbs -->
    <div class="parallax-orb w-96 h-96 bg-red -top-24 -left-24" data-parallax="-0.06"></div>
    <div class="parallax-orb w-64 h-64 bg-white bottom-0 right-12" data-parallax="0.04"></div>

    <div class="max-w-7xl mx-auto">
      <!-- Back link -->
      <a
        href="/races"
        class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.15em] text-red hover:text-white transition-colors mb-8"
        data-reveal
      >
        ← Back to Results
      </a>

      <!-- Live badge -->
      <div class="flex items-center gap-3 mb-4" data-reveal>
        <span class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] text-red bg-red/10 px-3 py-1.5 border border-red/30">
          <span class="w-2 h-2 bg-red rounded-full animate-pulse"></span>
          Live
        </span>
      </div>

      <!-- Title -->
      <h1
        class="font-display text-5xl md:text-7xl lg:text-8xl text-white leading-[0.9] mb-3"
        data-reveal
      >
        LIVE LEADERBOARD
      </h1>
      <p class="text-sm uppercase tracking-[0.15em] text-red mb-6" data-reveal>
        Real-Time Race Results
      </p>

      <div class="red-line mb-6" data-reveal></div>

      <p class="text-gray-3 text-sm md:text-base max-w-2xl" data-reveal>
        Real-time race results updated live. Watch the leaderboard as drivers compete.
      </p>
    </div>
  </section>

  <!-- Live leaderboard area -->
  <section class="pb-24 px-6 md:px-16 lg:px-24">
    <div class="max-w-7xl mx-auto">

      <!-- Leaderboard table -->
      <div class="border border-gray-1/30 overflow-x-auto" data-reveal>
        <table class="leaderboard-table">
          <thead>
            <tr class="bg-bg">
              <th class="w-16">POS</th>
              <th>DRIVER</th>
              <th>BEST LAP</th>
              <th class="hidden sm:table-cell">GAP</th>
              <th class="hidden md:table-cell">SIMULATOR</th>
            </tr>
          </thead>
          <tbody id="live-leaderboard">
            <!-- Rows populated via JS or manually -->
          </tbody>
        </table>
      </div>

      <!-- Empty state (shown when no data yet) -->
      <div
        id="empty-state"
        class="border border-gray-1/30 border-t-0 bg-surface py-16 flex flex-col items-center justify-center gap-3"
        data-reveal
      >
        <span class="inline-flex items-center gap-2 font-display text-2xl text-gray-2">
          <span class="w-2 h-2 bg-red rounded-full animate-pulse"></span>
          WAITING FOR RESULTS
        </span>
        <span class="text-xs uppercase tracking-[0.2em] text-gray-3">
          Leaderboard will update as drivers complete their laps
        </span>
      </div>

    </div>
  </section>

  <Footer isSubpage />
</BaseLayout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .animate-pulse {
    animation: pulse 2s ease-in-out infinite;
  }
</style>
