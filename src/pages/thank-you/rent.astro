---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
---

<BaseLayout title="Thank You — SimsForHire" ogTitle="INQUIRY RECEIVED" ogSubtitle="We'll be in touch within 24 hours">
  <Navbar isSubpage />
  <main class="min-h-screen flex items-center justify-center px-6 py-32">
    <div class="max-w-xl mx-auto text-center">

      <!-- Checkmark -->
      <div class="w-20 h-20 mx-auto mb-8 border-2 border-red rounded-full flex items-center justify-center">
        <svg class="w-10 h-10 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-display text-4xl md:text-6xl text-white tracking-wide mb-4">INQUIRY RECEIVED</h1>
      <div class="w-12 h-0.5 bg-red mx-auto mb-6"></div>

      <p class="text-gray text-base leading-relaxed mb-4">
        Thanks for reaching out! Our team is already reviewing your event inquiry
        and will get back to you within <strong class="text-white">24 hours</strong> with a custom quote.
      </p>

      <p class="text-gray text-sm mb-8">
        We sent a confirmation email to your inbox with all the details.
      </p>

      <!-- What happens next -->
      <div class="border border-gray-border p-6 mb-8 text-left">
        <p class="text-[10px] uppercase tracking-[0.4em] text-red mb-4">What Happens Next</p>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="text-red font-display text-lg">01</span>
            <p class="text-gray text-sm">We review your event details and put together a tailored package</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red font-display text-lg">02</span>
            <p class="text-gray text-sm">You'll receive a custom quote via email or phone within 24 hours</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red font-display text-lg">03</span>
            <p class="text-gray text-sm">Once approved, we schedule delivery and handle everything from there</p>
          </div>
        </div>
      </div>

      <!-- Urgent CTA -->
      <div class="bg-red/10 border border-red/20 p-6 mb-8">
        <p class="text-[10px] uppercase tracking-[0.3em] text-red mb-2">Need something sooner?</p>
        <a href="tel:7542285654" class="font-display text-2xl md:text-3xl text-white hover:text-red transition-colors">(754) 228-5654</a>
        <p class="text-gray text-xs mt-1">Available 24/7 — we can do 48-hour turnarounds</p>
      </div>

      <a href="/" class="inline-block border border-gray-border text-white px-8 py-3 text-sm font-display uppercase tracking-[0.25em] hover:border-red/40 transition-colors">
        Back to Home
      </a>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Fire Google Ads conversion on thank-you page load
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'rent_lead_thankyou',
    event_category: 'conversion',
    event_label: 'rent_form_complete',
  })
</script>
