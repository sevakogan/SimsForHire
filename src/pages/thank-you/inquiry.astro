---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
---

<BaseLayout title="Thank You — SimsForHire" ogTitle="THANKS FOR YOUR INTEREST" ogSubtitle="We'll be in touch within 24 hours">
  <Navbar isSubpage />
  <main class="min-h-screen flex items-center justify-center px-6 py-32">
    <div class="max-w-xl mx-auto text-center">

      <!-- Checkmark -->
      <div class="w-20 h-20 mx-auto mb-8 border-2 border-red rounded-full flex items-center justify-center">
        <svg class="w-10 h-10 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-display text-4xl md:text-6xl text-white tracking-wide mb-4">GOT IT!</h1>
      <div class="w-12 h-0.5 bg-red mx-auto mb-6"></div>

      <p class="text-gray text-base leading-relaxed mb-4">
        Thanks for your interest! We'll reach out within <strong class="text-white">24 hours</strong>
        to learn more about what you're looking for.
      </p>

      <p class="text-gray text-sm mb-8">
        Check your inbox — we just sent you a confirmation email.
      </p>

      <!-- What we do -->
      <div class="border border-gray-border p-6 mb-8 text-left">
        <p class="text-[10px] uppercase tracking-[0.4em] text-red mb-4">What We Offer</p>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="text-red font-bold">→</span>
            <div>
              <p class="text-white text-sm font-semibold">Rent for Events</p>
              <p class="text-gray text-xs">Full-motion simulators delivered to your venue. Setup, operation, teardown — all handled.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red font-bold">→</span>
            <div>
              <p class="text-white text-sm font-semibold">Lease Monthly</p>
              <p class="text-gray text-xs">Simulators installed at your business with full maintenance and support from $2,700+/mo.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red font-bold">→</span>
            <div>
              <p class="text-white text-sm font-semibold">Buy a Simulator</p>
              <p class="text-gray text-xs">Turnkey or custom-built rigs for your home, office, or venue.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Urgent CTA -->
      <div class="bg-red/10 border border-red/20 p-6 mb-8">
        <p class="text-[10px] uppercase tracking-[0.3em] text-red mb-2">Can't wait?</p>
        <a href="tel:7542285654" class="font-display text-2xl md:text-3xl text-white hover:text-red transition-colors">(754) 228-5654</a>
        <p class="text-gray text-xs mt-1">Call or text us anytime — we're available 24/7</p>
      </div>

      <a href="/" class="inline-block border border-gray-border text-white px-8 py-3 text-sm font-display uppercase tracking-[0.25em] hover:border-red/40 transition-colors">
        Back to Home
      </a>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: 'popup_lead_thankyou',
    event_category: 'conversion',
    event_label: 'popup_form_complete',
  })
</script>
