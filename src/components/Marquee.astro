---
import { MARQUEE_ITEMS } from '../data/content'

const doubled = [...MARQUEE_ITEMS, ...MARQUEE_ITEMS]
---

<div class="relative border-y border-red/30 bg-surface carbon-weave overflow-hidden py-5">
  <!-- Red glow line top -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-red/40 to-transparent"></div>

  <div class="marquee-track flex whitespace-nowrap">
    {doubled.map((item) => (
      <span class="inline-flex items-center gap-8 px-8">
        <span class="font-display text-2xl md:text-3xl tracking-[0.15em] text-white/80">{item}</span>
        <span class="text-red text-sm">&#9670;</span>
      </span>
    ))}
  </div>

  <!-- Red glow line bottom -->
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-red/40 to-transparent"></div>
</div>
