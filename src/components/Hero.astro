---
import { HERO } from '../data/content'
---

<section id="hero" class="relative h-screen w-full overflow-hidden">
  <!-- YouTube video background — parallax (moves slower) -->
  <div class="hero-bg-layer absolute inset-0 pointer-events-none" data-parallax="0.3">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${HERO.videoId}?autoplay=1&mute=1&loop=1&playlist=${HERO.videoId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1&iv_load_policy=3&disablekb=1`}
      title="SimsForHire Racing Simulators"
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[177.78vh] min-w-full min-h-full h-[56.25vw]"
      style="border: none;"
      allow="autoplay; encrypted-media"
      referrerpolicy="strict-origin-when-cross-origin"
    ></iframe>
  </div>

  <!-- Dark overlay — parallax (moves slower) -->
  <div class="hero-bg-layer absolute inset-0 bg-gradient-to-b from-black/80 via-black/60 to-bg z-[1]" data-parallax="0.3"></div>

  <!-- Speed lines decoration -->
  <div class="speed-lines absolute inset-0 z-[2]" data-parallax="0.15"></div>

  <!-- Floating red orb — drifts on scroll -->
  <div class="parallax-orb w-[500px] h-[500px] bg-red top-1/4 -right-32 z-[3]" data-parallax="-0.1"></div>

  <!-- Content — left aligned, moves at normal speed -->
  <div class="hero-content-layer relative z-10 flex h-full flex-col justify-center px-6 md:px-16 lg:px-24 max-w-7xl mx-auto">
    <!-- Red accent bar -->
    <div
      class="red-line hero-animate mb-8"
      style="animation-delay: 0.2s;"
    ></div>

    <!-- Heading line 1 -->
    <h1
      class="font-display text-6xl md:text-8xl lg:text-[10rem] font-bold text-white leading-[0.9] hero-animate"
      style="animation-delay: 0.35s;"
    >
      {HERO.headingLine1}
    </h1>

    <!-- Heading line 2 — with red accent -->
    <h1
      class="font-display text-6xl md:text-8xl lg:text-[10rem] font-bold text-red leading-[0.9] hero-animate"
      style="animation-delay: 0.5s;"
    >
      {HERO.headingLine2}
    </h1>

    <!-- Subtext -->
    <p
      class="text-base md:text-lg text-gray-3 mt-8 max-w-xl font-body hero-animate"
      style="animation-delay: 0.65s;"
    >
      {HERO.subtext}
    </p>

    <!-- Buttons -->
    <div
      class="mt-10 flex gap-4 flex-wrap hero-animate"
      style="animation-delay: 0.8s;"
    >
      <a
        href={HERO.ctaPrimary.href}
        class="bg-red text-white px-10 py-4 text-sm font-display font-semibold uppercase tracking-[0.2em] hover:bg-red-dark hover:shadow-[0_0_25px_rgba(225,6,0,0.3)] transition-all"
      >
        {HERO.ctaPrimary.label}
      </a>
      <a
        href={HERO.ctaSecondary.href}
        class="border border-white/20 px-10 py-4 text-sm font-display font-semibold uppercase tracking-[0.2em] text-gray-3 hover:border-red hover:text-red transition-all"
      >
        {HERO.ctaSecondary.label}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-10 hero-animate"
    style="animation-delay: 1s;"
  >
    <span class="text-[8px] tracking-[0.4em] text-white/30 uppercase font-body">
      SCROLL
    </span>
    <div class="w-px h-8 bg-gradient-to-b from-white/20 to-red"></div>
  </div>
</section>
