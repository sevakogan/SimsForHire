---
import { SERVICES } from '../data/content'
---

<section id="services" class="relative py-24 px-6 md:px-16 lg:px-24 max-w-7xl mx-auto overflow-hidden">
  <!-- Floating orb -->
  <div class="parallax-orb w-[400px] h-[400px] bg-red -left-32 bottom-0" data-parallax="0.08"></div>

  <!-- Section header -->
  <div data-reveal class="mb-16 relative z-10">
    <span class="text-xs uppercase tracking-[0.3em] text-red font-body">What We Do</span>
    <h2 class="font-display text-5xl md:text-7xl text-white mt-2">SERVICES</h2>
    <div class="red-line mt-4"></div>
  </div>

  <!-- Services grid -->
  <div class="grid md:grid-cols-2 gap-6 relative z-10">
    {SERVICES.map((service, i) => (
      <div data-reveal data-parallax={`${0.02 + (i % 2) * 0.03}`} class="racing-card carbon-weave p-8 relative">
        <!-- Number watermark — drifts -->
        <span class="watermark top-2 right-6 text-[5rem]" data-parallax="-0.1">{service.number}</span>

        <div class="relative z-10">
          <h3 class="font-display text-2xl text-white mb-3">{service.title}</h3>
          <p class="text-gray-3 text-sm leading-relaxed">{service.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
