---
import { EVENTS } from '../data/content'

const stripEvents = [...EVENTS, ...EVENTS]
---

<section id="events" class="py-16 md:py-24 overflow-hidden">
  <!-- Section label -->
  <div class="px-6 md:px-16 lg:px-24 max-w-7xl mx-auto mb-8 flex items-center justify-between">
    <p class="text-[10px] uppercase tracking-[0.4em] text-red" data-reveal>Past Events</p>

    <!-- Speed arrows -->
    <div class="flex items-center gap-3" data-reveal>
      <button id="strip-slower" class="text-gray-dim hover:text-white transition-colors p-1" aria-label="Slow down">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>
      <span id="strip-speed-label" class="text-gray-dim text-[10px] uppercase tracking-wider w-8 text-center">1x</span>
      <button id="strip-faster" class="text-gray-dim hover:text-white transition-colors p-1" aria-label="Speed up">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Continuous scrolling strip — big cards -->
  <div class="relative" data-reveal>
    <div id="event-strip" class="event-strip-track flex gap-5 w-max">
      {stripEvents.map((event) => (
        <a
          href={`/events/${event.slug}`}
          class="event-card relative w-[400px] md:w-[560px] lg:w-[640px] h-[280px] md:h-[380px] lg:h-[420px] flex-shrink-0 overflow-hidden group block"
          data-video-id={'videoId' in event ? event.videoId : undefined}
        >
          {'videoId' in event && event.videoId ? (
            <iframe
              class="event-video absolute inset-0 w-full h-full pointer-events-none"
              src={`https://www.youtube-nocookie.com/embed/${event.videoId}?autoplay=1&mute=1&loop=1&playlist=${event.videoId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1&iv_load_policy=3&disablekb=1`}
              title={event.name}
              style="border: none; transform: scale(1.5); transform-origin: center;"
              allow="autoplay; encrypted-media"
            ></iframe>
          ) : 'images' in event && event.images && event.images[0] ? (
            <img
              src={event.images[0].src}
              alt={event.images[0].alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          ) : (
            <div class="absolute inset-0 bg-surface"></div>
          )}

          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-[2]"></div>

          <!-- Sound indicator -->
          {'videoId' in event && event.videoId && (
            <div class="absolute top-4 left-4 z-10 bg-black/70 backdrop-blur-sm px-2.5 py-1.5 flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-3.5 h-3.5 text-red" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.999 3.002a1 1 0 0 1 1 1v15.996a1 1 0 0 1-1.625.78L5.87 16.5H2.999a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1h2.873l5.5-4.276a1 1 0 0 1 1.626.78zM15.5 8.5a.75.75 0 0 1 1.06 0 4.5 4.5 0 0 1 0 6.364.75.75 0 1 1-1.06-1.06 3 3 0 0 0 0-4.243.75.75 0 0 1 0-1.06z"/>
              </svg>
              <span class="text-[9px] uppercase tracking-wider text-white">Sound on</span>
            </div>
          )}

          <!-- Stats badge -->
          {'stats' in event && event.stats && (
            <div class="absolute top-4 right-4 bg-black/70 backdrop-blur-sm px-3 py-1.5 z-10">
              <span class="font-display text-lg text-white">{event.stats.people}</span>
              <span class="text-[9px] uppercase tracking-wider text-gray ml-1">guests</span>
            </div>
          )}

          <!-- Text -->
          <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 z-[3]">
            <span class="text-[10px] uppercase tracking-[0.3em] text-red">{event.type}</span>
            <h3 class="font-display text-3xl md:text-4xl text-white mt-1">{event.name}</h3>
            <p class="text-gray text-xs mt-1">{event.date}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Speed control for the CSS animation
  const strip = document.getElementById('event-strip')!
  const slowerBtn = document.getElementById('strip-slower')!
  const fasterBtn = document.getElementById('strip-faster')!
  const speedLabel = document.getElementById('strip-speed-label')!

  const speeds = [
    { label: '0.5x', duration: '50s' },
    { label: '1x', duration: '30s' },
    { label: '2x', duration: '15s' },
    { label: '3x', duration: '10s' },
  ]
  let speedIndex = 1

  function applySpeed() {
    strip.style.animationDuration = speeds[speedIndex].duration
    speedLabel.textContent = speeds[speedIndex].label
  }

  fasterBtn.addEventListener('click', () => {
    if (speedIndex < speeds.length - 1) speedIndex++
    applySpeed()
  })

  slowerBtn.addEventListener('click', () => {
    if (speedIndex > 0) speedIndex--
    applySpeed()
  })

  // Pause on hover
  strip.addEventListener('mouseenter', () => { strip.style.animationPlayState = 'paused' })
  strip.addEventListener('mouseleave', () => { strip.style.animationPlayState = 'running' })

  // Hover to unmute videos
  document.querySelectorAll<HTMLElement>('.event-card[data-video-id]').forEach((card) => {
    const iframe = card.querySelector<HTMLIFrameElement>('.event-video')
    if (!iframe) return
    card.addEventListener('mouseenter', () => {
      iframe.contentWindow?.postMessage(JSON.stringify({ event: 'command', func: 'unMute' }), '*')
    })
    card.addEventListener('mouseleave', () => {
      iframe.contentWindow?.postMessage(JSON.stringify({ event: 'command', func: 'mute' }), '*')
    })
  })
</script>
