---
import { ABOUT } from '../data/content'
---

<section id="about" class="relative py-24 px-6 md:px-16 lg:px-24 max-w-7xl mx-auto overflow-hidden">
  <!-- Watermark — drifts on scroll -->
  <span class="watermark top-8 right-8" data-parallax="-0.15">05</span>

  <!-- Floating orb -->
  <div class="parallax-orb w-[500px] h-[500px] bg-red left-1/3 -top-32" data-parallax="-0.1"></div>

  <div class="grid md:grid-cols-2 gap-16 items-start relative z-10">
    <!-- Text column -->
    <div data-reveal>
      <span class="text-xs uppercase tracking-[0.3em] text-red font-body">Who We Are</span>
      <h2 class="font-display text-5xl md:text-7xl text-white mt-2 mb-6">{ABOUT.heading}</h2>
      <div class="red-line mb-8"></div>

      {ABOUT.paragraphs.map((p) => (
        <p class="text-gray-3 text-sm leading-relaxed mb-6">{p}</p>
      ))}

      <a
        href={ABOUT.shiftArcadeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-red text-sm uppercase tracking-[0.15em] hover:text-white transition-colors mt-2"
      >
        Visit ShiftArcade
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="square" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    </div>

    <!-- Image placeholders — staggered parallax -->
    <div data-reveal class="grid grid-cols-2 gap-4">
      <div class="overflow-hidden">
        <div class="bg-surface border border-gray-1/30 aspect-[3/4] flex items-center justify-center" data-parallax="0.06">
          <span class="text-gray-2 text-xs uppercase tracking-wider">Image</span>
        </div>
      </div>
      <div class="overflow-hidden mt-8">
        <div class="bg-surface border border-gray-1/30 aspect-[3/4] flex items-center justify-center" data-parallax="0.1">
          <span class="text-gray-2 text-xs uppercase tracking-wider">Image</span>
        </div>
      </div>
    </div>
  </div>
</section>
