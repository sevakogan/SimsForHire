---
import { ABOUT } from '../data/content'
---

<section id="about" class="py-28 md:py-40 px-6">
  <div class="max-w-[980px] mx-auto grid md:grid-cols-2 gap-16 items-center">
    <!-- Text column -->
    <div data-reveal>
      <p class="text-red text-sm font-medium mb-3">Who We Are</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] font-semibold text-headline tracking-tight mb-6">
        Built for the Love of Racing
      </h2>

      {ABOUT.paragraphs.map((p) => (
        <p class="text-body text-base font-light leading-relaxed mb-5">{p}</p>
      ))}

      <a
        href={ABOUT.shiftArcadeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-red text-sm hover:underline mt-2 group"
      >
        Visit ShiftArcade
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    </div>

    <!-- Image -->
    <div data-reveal class="overflow-hidden rounded-2xl shadow-lg">
      <img
        src="/images/full_motion_2.jpg"
        alt="SimsForHire full-motion racing simulator"
        class="w-full aspect-[4/5] object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
