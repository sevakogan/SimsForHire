<section class="py-16 md:py-20 px-6 md:px-16 lg:px-24 bg-red relative overflow-hidden">
  <!-- Subtle pattern -->
  <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(135deg, transparent, transparent 40px, rgba(0,0,0,0.1) 40px, rgba(0,0,0,0.1) 42px);"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10" data-reveal>
    <h2 class="font-display text-4xl md:text-6xl text-white tracking-wide mb-2">
      RENT A SIM
    </h2>
    <p class="font-display text-6xl md:text-8xl lg:text-9xl text-white tracking-tight leading-none mb-1">
      <span class="italic">$</span>2,500<span class="text-white/60 text-2xl md:text-3xl align-top">*</span>
    </p>
    <p class="text-white/50 text-xs uppercase tracking-widest mb-6">*Events starting at</p>

    <p class="text-white/80 text-base mb-8 max-w-xl mx-auto">
      From call to showtime in 48 hours. Full-motion simulators delivered, set up, and operated at your venue. We handle everything.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="tel:7542285654"
