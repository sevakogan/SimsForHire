---
import { TESTIMONIALS } from '../data/content'

// Pick one killer quote
const quote = TESTIMONIALS[0]
---

<section class="py-20 md:py-28 px-6 md:px-16 lg:px-24">
  <div class="max-w-4xl mx-auto text-center" data-reveal="scale">
    <span class="font-display text-7xl text-red leading-none block mb-6">&ldquo;</span>
    <p class="font-display text-2xl md:text-4xl text-white leading-snug tracking-wide">
      {quote.quote}
    </p>
    <div class="mt-8">
      <p class="text-white text-sm font-medium">{quote.author}</p>
      <p class="text-gray text-xs mt-1">{quote.role}</p>
    </div>
  </div>
</section>
