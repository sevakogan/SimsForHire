---
import { CONTACT } from '../data/content'
---

<section id="contact" class="py-24 md:py-32 px-6 md:px-16 lg:px-24 border-t border-gray-border">
  <div class="max-w-2xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-12" data-reveal>
      <h2 class="font-display text-5xl md:text-7xl text-white tracking-wide">BOOK YOUR EVENT</h2>
      <p class="text-gray text-sm mt-4">
        Tell us about your event and we'll get back to you within 24 hours.
      </p>
      <p class="text-red/80 text-xs mt-2 uppercase tracking-widest">
        48-hour setup available — we operate 24/7
      </p>
    </div>

    <!-- Form — simplified -->
    <form id="contact-form" data-reveal>
      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div class="form-field">
          <input
            type="text" id="name" name="name" required placeholder="Name *"
            class="w-full bg-surface border border-gray-border px-4 py-3.5 text-sm text-white placeholder:text-gray-dim transition-all"
          />
          <span class="field-error text-red text-[10px] mt-1 hidden">Required</span>
        </div>
        <div class="form-field">
          <input
            type="email" id="email" name="email" required placeholder="Email *"
            class="w-full bg-surface border border-gray-border px-4 py-3.5 text-sm text-white placeholder:text-gray-dim transition-all"
          />
          <span class="field-error text-red text-[10px] mt-1 hidden">Valid email required</span>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div class="form-field">
          <select
            id="eventType" name="eventType"
            class="w-full bg-surface border border-gray-border px-4 py-3.5 text-sm text-white transition-all appearance-none"
          >
            <option value="" class="bg-bg text-gray-dim">Event Type</option>
            <option value="Corporate Event" class="bg-bg">Corporate Event</option>
            <option value="Private Party" class="bg-bg">Private Party</option>
            <option value="Trade Show" class="bg-bg">Trade Show</option>
            <option value="Brand Activation" class="bg-bg">Brand Activation</option>
            <option value="Other" class="bg-bg">Other</option>
          </select>
        </div>
        <div class="form-field">
          <input
            type="tel" id="phone" name="phone" placeholder="Phone (optional)"
            class="w-full bg-surface border border-gray-border px-4 py-3.5 text-sm text-white placeholder:text-gray-dim transition-all"
          />
        </div>
      </div>

      <div class="mb-4 form-field">
        <textarea
          id="message" name="message" rows="3" placeholder="Tell us about your event (optional)"
          class="w-full bg-surface border border-gray-border px-4 py-3.5 text-sm text-white placeholder:text-gray-dim transition-all resize-none"
        ></textarea>
      </div>

      <!-- SMS consent -->
      <div class="mb-6">
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" id="smsConsent" name="smsConsent" class="mt-1 w-4 h-4 accent-red flex-shrink-0" />
          <span class="text-gray-dim text-xs leading-relaxed group-hover:text-gray transition-colors">
            I agree to receive booking-related texts from SimsForHire.
            Msg & data rates may apply. Reply <strong class="text-white">STOP</strong> to opt out.
            <a href="/privacy-policy" target="_blank" class="text-red hover:text-white transition-colors">Privacy</a> &amp;
            <a href="/terms-and-conditions" target="_blank" class="text-red hover:text-white transition-colors">Terms</a>.
          </span>
        </label>
      </div>

      <!-- Submit -->
      <button
        type="submit" id="submit-btn"
        class="w-full bg-red text-white py-5 text-sm font-display uppercase tracking-[0.25em] cursor-pointer relative z-10 hover:bg-[#ff1a1a] hover:shadow-[0_0_30px_rgba(225,6,0,0.3)] active:scale-[0.99] transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span id="btn-text">Send Inquiry</span>
        <span id="btn-loading" class="hidden">Sending...</span>
      </button>

      <!-- Status messages -->
      <div id="form-success" class="hidden mt-6 p-4 border border-green-500/30 bg-green-500/10 text-center">
        <p class="text-green-400 text-sm font-display uppercase tracking-wider">Message sent!</p>
        <p class="text-gray text-xs mt-1">We'll get back to you within 24 hours.</p>
      </div>
      <div id="form-error" class="hidden mt-6 p-4 border border-red/30 bg-red/10 text-center">
        <p class="text-red text-sm font-display uppercase tracking-wider">Something went wrong</p>
        <p class="text-gray text-xs mt-1">Please try again or email us at {CONTACT.email}</p>
      </div>
    </form>

    <!-- Contact details -->
    <div class="grid grid-cols-3 gap-4 mt-12 text-center" data-reveal>
      <div>
        <span class="text-[10px] uppercase tracking-[0.25em] text-gray-dim block mb-1">Email</span>
        <a href={`mailto:${CONTACT.email}`} class="text-white text-sm hover:text-red transition-colors">{CONTACT.email}</a>
      </div>
      <div>
        <span class="text-[10px] uppercase tracking-[0.25em] text-gray-dim block mb-1">Phone</span>
        <a href={`tel:${CONTACT.phone.replace(/\D/g, '')}`} class="text-white text-sm hover:text-red transition-colors">{CONTACT.phone}</a>
      </div>
      <div>
        <span class="text-[10px] uppercase tracking-[0.25em] text-gray-dim block mb-1">Location</span>
        <span class="text-white text-sm">{CONTACT.location}</span>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const btnText = document.getElementById('btn-text')!
  const btnLoading = document.getElementById('btn-loading')!
  const successMsg = document.getElementById('form-success')!
  const errorMsg = document.getElementById('form-error')!

  function getCookie(name: string): string | undefined {
    const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'))
    return match?.[2]
  }

  const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]')
  requiredFields.forEach((field) => {
    field.addEventListener('blur', () => {
      const parent = field.closest('.form-field')
      if (!parent) return
      if (!field.value.trim() || (field.type === 'email' && !field.validity.valid)) {
        parent.classList.add('has-error')
      } else {
        parent.classList.remove('has-error')
      }
    })
    field.addEventListener('input', () => {
      const parent = field.closest('.form-field')
      if (parent?.classList.contains('has-error') && field.value.trim()) {
        if (field.type !== 'email' || field.validity.valid) {
          parent.classList.remove('has-error')
        }
      }
    })
  })

  form.addEventListener('submit', async (e) => {
    e.preventDefault()

    let hasErrors = false
    requiredFields.forEach((field) => {
      const parent = field.closest('.form-field')
      if (!parent) return
      if (!field.value.trim() || (field.type === 'email' && !field.validity.valid)) {
        parent.classList.add('has-error')
        hasErrors = true
      }
    })
    if (hasErrors) return

    successMsg.classList.add('hidden')
    errorMsg.classList.add('hidden')
    submitBtn.disabled = true
    btnText.classList.add('hidden')
    btnLoading.classList.remove('hidden')

    const formData = new FormData(form)
    const data = Object.fromEntries(formData.entries())

    const eventId = crypto.randomUUID?.() ?? `${Date.now()}-${Math.random().toString(36).slice(2)}`

    if (typeof fbq !== 'undefined') {
      fbq('track', 'Lead', {
        content_category: data.eventType || 'General Inquiry',
        content_name: 'Hire Inquiry Form',
      }, { eventID: eventId })
    }
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'rent_lead',
      event_category: 'lead',
      event_label: 'rent_inquiry_form',
    })

    // Attach UTM params for attribution tracking
    const utmRaw = sessionStorage.getItem('s4h_utm')
    const utmData = utmRaw ? JSON.parse(utmRaw) : {}
    const landingPage = sessionStorage.getItem('s4h_landing') || undefined

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...data,
          eventId,
          sourceUrl: window.location.href,
          fbc: getCookie('_fbc'),
          fbp: getCookie('_fbp'),
          ...utmData,
          landingPage,
        }),
      })

      if (!response.ok) throw new Error('Failed')

      window.location.href = '/thank-you/rent'
    } catch {
      errorMsg.classList.remove('hidden')
    } finally {
      submitBtn.disabled = false
      btnText.classList.remove('hidden')
      btnLoading.classList.add('hidden')
    }
  })
</script>
