---
import { SITE } from '../data/content'

interface Props {
  isSubpage?: boolean
}

const { isSubpage = false } = Astro.props
const year = new Date().getFullYear()
---

<footer class="border-t border-gray-border py-8 px-6 md:px-16 lg:px-24">
  <div class="max-w-7xl mx-auto flex flex-col items-center gap-6 text-xs text-gray-dim">
    <!-- Logo -->
    <a href={isSubpage ? '/' : '#'}>
      <img src="/images/simsforhire-logo-white.png" alt={SITE.name} class="h-8 w-auto opacity-60" />
    </a>

    <p>&copy; {year} {SITE.name}. A <a href="https://shiftarcade.com" target="_blank" rel="noopener noreferrer" class="text-gray hover:text-white transition-colors">ShiftArcade</a> company.</p>

    <div class="flex items-center gap-4">
      {[
        { label: 'Instagram', href: 'https://instagram.com/simsforhire' },
        { label: 'TikTok', href: 'https://tiktok.com/@simsforhire' },
        { label: 'YouTube', href: 'https://youtube.com/@simsforhire' },
      ].map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-gray-dim hover:text-red transition-colors">{s.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy</a>
      <span class="text-gray-border">|</span>
      <a href="/terms-and-conditions" class="hover:text-white transition-colors">Terms</a>
      <span class="text-gray-border">|</span>
      <a href="/races" class="hover:text-white transition-colors">Races</a>
    </div>
  </div>
</footer>
