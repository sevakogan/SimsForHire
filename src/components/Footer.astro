---
import { SITE, NAV_LINKS } from '../data/content'

const year = new Date().getFullYear()
---

<footer class="bg-bg border-t border-gray-1/20 py-12 px-6 md:px-16 lg:px-24">
  <div class="max-w-7xl mx-auto">
    <!-- Top section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-8">
      <!-- Logo -->
      <div>
        <a href="#" class="font-display text-2xl tracking-tight text-white">
          {SITE.name}
        </a>
        <p class="text-gray-2 text-xs mt-2">
          A <a href="https://shiftarcade.com" target="_blank" rel="noopener noreferrer" class="text-red hover:text-white transition-colors">ShiftArcade</a> company
        </p>
      </div>

      <!-- Nav links -->
      <div class="flex flex-wrap gap-6">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="text-xs uppercase tracking-[0.2em] text-gray-2 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Red accent line -->
    <div class="w-full h-px bg-gradient-to-r from-red/50 via-red to-red/50 mb-8"></div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-2 text-xs">
        &copy; {year} {SITE.name}. All rights reserved.
      </p>
      <p class="text-gray-2 text-xs">
        Miami, FL
      </p>
    </div>
  </div>
</footer>
