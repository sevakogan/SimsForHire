---
import { STATS } from '../data/content'
---

<section class="bg-dark-bg py-32 md:py-40 px-6">
  <div class="max-w-[980px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-reveal-stagger data-reveal>
      {STATS.map((stat) => (
        <div class="py-4">
          <span
            class="font-display text-[clamp(3rem,8vw,5rem)] font-bold text-white tracking-tight leading-none"
            data-count-value={stat.value}
          >
            {stat.value}
          </span>
          <span class="font-display text-[clamp(3rem,8vw,5rem)] font-bold text-white tracking-tight leading-none">
            {stat.suffix}
          </span>
          <span class="block text-secondary text-sm font-light mt-3">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('[data-count-value]')
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue
        const el = entry.target as HTMLElement
        const raw = el.dataset.countValue ?? '0'
        const isFloat = raw.includes('.')
        const target = isFloat ? parseFloat(raw) : parseInt(raw.replace(/\D/g, ''))
        const suffix = raw.replace(/[\d.]/g, '')
        const duration = 2000
        const start = performance.now()

        function tick(now: number) {
          const elapsed = now - start
          const progress = Math.min(elapsed / duration, 1)
          const eased = 1 - Math.pow(1 - progress, 4)
          const current = isFloat
            ? (target * eased).toFixed(1)
            : Math.floor(target * eased)
          el.textContent = `${current}${suffix}`
          if (progress < 1) requestAnimationFrame(tick)
        }

        requestAnimationFrame(tick)
        observer.unobserve(el)
      }
    },
    { threshold: 0.5 }
  )

  counters.forEach((el) => observer.observe(el))
</script>
